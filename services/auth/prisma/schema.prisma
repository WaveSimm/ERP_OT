generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  passwordHash   String          @map("password_hash")
  role           UserRole        @default(OPERATOR)
  isActive       Boolean         @default(true) @map("is_active")
  // 자원-모델-분리 PDCA Phase 1 (2026-05-04): 직원 라이프사이클
  status         EmployeeStatus  @default(ACTIVE)
  retirementDate DateTime?       @db.Date @map("retirement_date")
  lastLoginAt    DateTime?       @map("last_login_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  profile       UserProfile?
  posts         Post[]    @relation("PostAuthor")
  assignedPosts Post[]    @relation("PostAssignee")
  comments      Comment[] @relation("CommentAuthor")
  attachments   Attachment[] @relation("AttachmentUploader")
  postReads     PostRead[]

  @@index([status])
  @@map("auth_users")
}

// 자원-모델-분리 PDCA Phase 1 (2026-05-04): 직원 상태
//   ACTIVE: 현직 — 모든 기능 정상
//   RETIRED: 퇴직 — 데이터 보존, 신규 배정·로그인·결재 차단 (isActive=false 자동)
//   SUSPENDED: 휴직·정지 — 일시 차단, 복귀 가능
enum EmployeeStatus {
  ACTIVE
  RETIRED
  SUSPENDED
}

model UserProfile {
  id             String      @id @default(cuid())
  userId         String      @unique @map("user_id")
  phoneOffice    String?     @map("phone_office")
  phoneMobile    String?     @map("phone_mobile")
  address        String?
  departmentId   String?     @map("department_id")
  departmentName String?     @map("department_name")
  hireDate       DateTime?   @map("hire_date")
  position       String?

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id])

  @@map("auth_user_profiles")
}

model Department {
  id           String      @id @default(cuid())
  name         String
  code         String      @unique
  level        Int         @default(1)
  parentId     String?     @map("parent_id")
  headUserId   String?     @map("head_user_id")
  soukwalUserId String?    @map("soukwal_user_id")
  daepyoUserId String?     @map("daepyo_user_id")
  isActive     Boolean     @default(true) @map("is_active")
  // 메뉴에서만 숨김 (관리 화면에는 계속 노출, 일반 픽커/드롭다운에서는 제외)
  hiddenFromMenus Boolean  @default(false) @map("hidden_from_menus")
  sortOrder    Int         @default(0) @map("sort_order")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  parent      Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children    Department[] @relation("DeptTree")
  members     UserProfile[]

  @@index([parentId])
  @@index([isActive])
  @@index([hiddenFromMenus])
  @@map("departments")
}

model ApprovalLine {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  approverId        String    @map("approver_id")
  secondApproverId  String?   @map("second_approver_id")
  thirdApproverId   String?   @map("third_approver_id")
  delegateId        String?   @map("delegate_id")
  delegateUntil     DateTime? @map("delegate_until")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([approverId])
  @@index([secondApproverId])
  @@index([thirdApproverId])
  @@map("approval_lines")
}

// 보안 일괄패치 PDCA Layer 3 (C5 + NEW-7 + reuse detection)
//   token (평문) → tokenHash (sha256 hex 64자)
//   deviceId/userAgent/ipAddress: NEW-7 다기기 식별 + audit
//   lastUsedAt/rotatedAt/rotatedToId: refresh reuse detection
model RefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique @map("token_hash") // SHA-256 hex
  userId      String    @map("user_id")
  deviceId    String?   @map("device_id")
  userAgent   String?   @map("user_agent")
  ipAddress   String?   @map("ip_address")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastUsedAt  DateTime  @default(now()) @map("last_used_at")
  rotatedAt   DateTime? @map("rotated_at")
  rotatedToId String?   @map("rotated_to_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([userId, deviceId])
  @@map("auth_refresh_tokens")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

// ─── 게시판 도메인 ─────────────────────────────────────────────────

model BoardCategory {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  isVisible Boolean  @default(true) @map("is_visible")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  boards    Board[]

  @@index([sortOrder])
  @@map("board_categories")
}

model Board {
  id              String   @id @default(cuid())
  categoryId      String   @map("category_id")
  code            String   @unique
  name            String
  description     String?

  writeRoles      String[] @map("write_roles")
  readAudience    BoardAudience @default(ALL) @map("read_audience")
  audienceTargetId String? @map("audience_target_id")

  allowComments    Boolean @default(true) @map("allow_comments")
  allowAttachments Boolean @default(true) @map("allow_attachments")
  postPinnable     Boolean @default(true) @map("post_pinnable")

  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category        BoardCategory @relation(fields: [categoryId], references: [id])
  posts           Post[]

  @@index([categoryId, sortOrder])
  @@index([isActive])
  @@map("boards")
}

model Post {
  id              String   @id @default(cuid())
  boardId         String   @map("board_id")
  authorId        String   @map("author_id")
  embedding       Unsupported("vector(1024)")?
  embeddedAt      DateTime?                        @map("embedded_at")

  publishingDepartmentId   String? @map("publishing_department_id")
  publishingDepartmentName String? @map("publishing_department_name")

  // 대상 부서 (부서 공지에서만 사용 — 작성자가 공지할 부서 선택)
  targetDepartmentId   String? @map("target_department_id")
  targetDepartmentName String? @map("target_department_name")

  title           String
  content         String   @db.Text

  isPinned        Boolean  @default(false) @map("is_pinned")
  priority        Int      @default(0)

  publishedAt     DateTime @default(now()) @map("published_at")
  expiresAt       DateTime? @map("expires_at")
  isDeleted       Boolean  @default(false) @map("is_deleted")

  viewCount       Int      @default(0) @map("view_count")

  // 기능 요구 카테고리 전용 (board.category.code='feature-request'일 때만 사용)
  // 게시판 design v2.0 (2026-05-22) 참조
  requestStatus    FeatureRequestStatus?  @map("request_status")
  requestType      FeatureRequestType?    @map("request_type")
  assigneeId       String?                @map("assignee_id")
  moduleArea       String?                @map("module_area")
  releaseVersion   String?                @map("release_version")
  resolvedAt       DateTime?              @map("resolved_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  board           Board       @relation(fields: [boardId], references: [id])
  author          User        @relation("PostAuthor", fields: [authorId], references: [id])
  assignee        User?       @relation("PostAssignee", fields: [assigneeId], references: [id])
  reads           PostRead[]
  comments        Comment[]
  attachments     Attachment[]

  @@index([boardId, isDeleted, isPinned, publishedAt(sort: Desc)])
  @@index([authorId])
  @@index([publishingDepartmentId])
  @@index([targetDepartmentId])
  @@index([requestStatus])
  @@index([requestType])
  @@index([assigneeId])
  @@map("board_posts")
}

enum FeatureRequestStatus {
  SUBMITTED       // 접수
  UNDER_REVIEW    // 검토 중
  APPROVED        // 승인 (개발 대기)
  IN_PROGRESS     // 진행 중
  COMPLETED       // 완료
  REJECTED        // 거부
  ON_HOLD         // 보류
}

enum FeatureRequestType {
  BUG             // 버그
  NEW_FEATURE     // 신규 기능
  IMPROVEMENT     // 개선
  UI_UX           // UI/UX
  DOCS            // 문서·매뉴얼
  OTHER
}

model PostRead {
  postId   String   @map("post_id")
  userId   String   @map("user_id")
  readAt   DateTime @default(now()) @map("read_at")

  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("board_post_reads")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  parentId  String?  @map("parent_id")
  content   String   @db.Text
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  parent    Comment? @relation("CommentTree", fields: [parentId], references: [id])
  children  Comment[] @relation("CommentTree")

  @@index([postId, createdAt(sort: Asc)])
  @@map("board_comments")
}

model Attachment {
  id          String   @id @default(cuid())
  postId      String?  @map("post_id")
  uploadedBy  String   @map("uploaded_by")
  fileName    String   @map("file_name")
  fileSize    Int      @map("file_size")
  mimeType    String   @map("mime_type")
  storageKey  String   @unique @map("storage_key")
  isInline    Boolean  @default(false) @map("is_inline")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")

  post        Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
  uploader    User  @relation("AttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([postId])
  @@index([uploadedBy])
  @@map("board_attachments")
}

enum BoardAudience {
  ALL
  DEPARTMENT
  ROLE
}

// ─── 회사 달력 ─────────────────────────────────────────────────────

model CompanyCalendarEntry {
  id          String              @id @default(cuid())
  type        CalendarEntryType
  title       String
  description String?
  startDate   DateTime            @db.Date @map("start_date")
  endDate     DateTime            @db.Date @map("end_date")
  isAllDay    Boolean             @default(true) @map("is_all_day")
  color       String?

  // 2차 활성화 컬럼 (nullable, 1차 미사용)
  recurrence         String?
  targetDepartmentId String?  @map("target_department_id")
  startTime          String?  @map("start_time")
  endTime            String?  @map("end_time")

  // 회사달력 v1.2 — 한국 공휴일 자동 갱신
  source     CalendarEntrySource @default(MANUAL)
  externalId String?             @map("external_id")  // KASI: ${locdate}-${dateName}

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([startDate, endDate])
  @@index([type])
  @@index([source])
  @@unique([source, externalId])
  @@map("company_calendar_entries")
}

enum CalendarEntryType {
  PUBLIC_HOLIDAY
  COMPANY_HOLIDAY
  EVENT
  WORKDAY
}

// 회사달력 v1.2 — 항목의 데이터 출처
//   MANUAL: 관리자 수동 등록 — sync 영향 없음 (보호)
//   KASI: 한국천문연구원 특일 정보 API 자동 import — sync로 upsert/delete
enum CalendarEntrySource {
  MANUAL
  KASI
}
