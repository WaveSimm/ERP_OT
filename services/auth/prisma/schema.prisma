generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String    @map("password_hash")
  role         UserRole  @default(OPERATOR)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  profile       UserProfile?

  @@map("auth_users")
}

model UserProfile {
  id             String      @id @default(cuid())
  userId         String      @unique @map("user_id")
  phoneOffice    String?     @map("phone_office")
  phoneMobile    String?     @map("phone_mobile")
  address        String?
  departmentId   String?     @map("department_id")
  departmentName String?     @map("department_name")
  hireDate       DateTime?   @map("hire_date")
  position       String?

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id])

  @@map("auth_user_profiles")
}

model Department {
  id           String      @id @default(cuid())
  name         String
  code         String      @unique
  level        Int         @default(1)
  parentId     String?     @map("parent_id")
  headUserId   String?     @map("head_user_id")
  soukwalUserId String?    @map("soukwal_user_id")
  daepyoUserId String?     @map("daepyo_user_id")
  isActive     Boolean     @default(true) @map("is_active")
  sortOrder    Int         @default(0) @map("sort_order")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  parent      Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children    Department[] @relation("DeptTree")
  members     UserProfile[]

  @@index([parentId])
  @@index([isActive])
  @@map("departments")
}

model ApprovalLine {
  id                String    @id @default(cuid())
  userId            String    @unique @map("user_id")
  approverId        String    @map("approver_id")
  secondApproverId  String?   @map("second_approver_id")
  thirdApproverId   String?   @map("third_approver_id")
  delegateId        String?   @map("delegate_id")
  delegateUntil     DateTime? @map("delegate_until")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([approverId])
  @@index([secondApproverId])
  @@index([thirdApproverId])
  @@map("approval_lines")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_refresh_tokens")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}
