generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["project"]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED

  @@schema("project")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  ON_HOLD
  DONE
  BLOCKED
  CANCELLED

  @@schema("project")
}

enum DependencyType {
  FS // Finish-to-Start
  SS // Start-to-Start
  FF // Finish-to-Finish
  SF // Start-to-Finish

  @@schema("project")
}

enum AllocationMode {
  PERCENT
  HOURS

  @@schema("project")
}

// Phase 5 (2026-05-13): ResourceType enum 폐기 (legacy Resource 모델 종속)
//   비인력 분류는 EquipmentType (VEHICLE/FACILITY/EQUIPMENT) 사용

// 자원-모델-분리 PDCA Phase 1 (2026-05-04)
// EQUIPMENT 타입 폐기 (2026-05-05) — 공용자산은 시설/차량만 관리, 프로젝트 미연계.
// "장비"는 /equipment 페이지의 Equipment 모델(프로젝트 연계 자산)로 이동.
enum EquipmentType {
  VEHICLE
  FACILITY

  @@schema("project")
}

enum ExternalStatus {
  ACTIVE      // 계약 중
  ARCHIVED    // 종료

  @@schema("project")
}

enum ResourceGroupType {
  PERSON      // 직원 그룹 (예: 부서, 팀)
  EXTERNAL    // 외부 자원 그룹
  EQUIPMENT   // 비인력 자원 그룹

  @@schema("project")
}

enum GroupType {
  DEPARTMENT
  CLIENT
  CUSTOM

  @@schema("project")
}

enum ChangeType {
  SEGMENT_ADDED
  SEGMENT_REMOVED
  DATE_CHANGED
  ASSIGNMENT_CHANGED
  PROGRESS_UPDATED
  STATUS_CHANGED
  COMMENT_ADDED
  COMMENT_EDITED
  COMMENT_DELETED

  @@schema("project")
}

enum TemplateScope {
  ORGANIZATION
  PERSONAL

  @@schema("project")
}

// ❌ MilestoneStatus, AchievementCriteria 폐기 — "마일스톤-시점태스크-회귀" PDCA에서 reverse
//    Task.isMilestone 플래그로 회귀, Task.status (TODO/IN_PROGRESS/DONE/BLOCKED) 사용

// ─────────────────────────────────────────────
// 1. 프로젝트 기본 구조
// ─────────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  name          String
  description   String?
  status        ProjectStatus @default(PLANNING)
  plannedBudget Decimal?      @db.Decimal(15, 2)
  actualBudget  Decimal?      @db.Decimal(15, 2)
  ownerId       String // user-service userId
  createdBy     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // 캐시 — 모든 leaf task segment 평균/min/max (TaskService hook으로 갱신)
  overallProgress    Float?    @map("overall_progress")
  effectiveStartDate DateTime? @map("effective_start_date")
  effectiveEndDate   DateTime? @map("effective_end_date")

  tasks            Task[]
  baselines        ProjectBaseline[]
  activityLogs     ActivityLog[]
  groupMemberships ProjectGroupMembership[]

  @@map("projects")
  @@schema("project")
}

// ❌ Milestone 모델 폐기 — "마일스톤-시점태스크-회귀" PDCA에서 reverse
//    Task에 isMilestone 플래그로 회귀, 시점 = 단일 segment(start=end)
//    마이그레이션은 services/project/prisma/migrations/{ts}_milestone_revert/migration.sql

// 단순화된 의존성 — Task ↔ Task만 ("마일스톤-시점태스크-회귀" PDCA에서 polymorphic 폐기)
model Dependency {
  id String @id @default(cuid())

  predecessorTaskId String
  successorTaskId   String

  dependencyType DependencyType @default(FS)
  lag            Int            @default(0) // days, can be negative

  createdBy String
  createdAt DateTime @default(now())

  predecessorTask Task @relation("PredecessorTask", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTask   Task @relation("SuccessorTask", fields: [successorTaskId], references: [id], onDelete: Cascade)

  @@unique([predecessorTaskId, successorTaskId])
  @@index([predecessorTaskId])
  @@index([successorTaskId])
  @@map("dependencies")
  @@schema("project")
}

// Task = 논리적 컨테이너 (직접 날짜 없음)
//   isMilestone=true: 시점 task (◆), 단일 segment(start=end), 자식 가질 수 없음
//   isMilestone=false: 일반 작업, 자식 가능, 다중 segment 가능
model Task {
  id               String     @id @default(cuid())
  projectId        String
  parentId         String? // WBS 계층 (상위 태스크)
  name             String
  description      String?
  status           TaskStatus @default(TODO)
  sortOrder        Int        @default(0)
  overallProgress  Float      @default(0) // 0~100
  isManualProgress Boolean    @default(false)
  isMilestone      Boolean    @default(false) // 시점 task (◆), CPM duration=0
  isCritical       Boolean    @default(false) // CPM 결과
  totalFloat       Float? // CPM 결과
  createdBy        String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // 캐시 — 자기 task의 segments min/max (TaskService hook으로 갱신)
  effectiveStartDate DateTime? @map("effective_start_date")
  effectiveEndDate   DateTime? @map("effective_end_date")

  project           Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent            Task?                 @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Task[]                @relation("TaskHierarchy")
  segments          TaskSegment[]
  comments          Comment[]
  attachments       Attachment[]
  scheduleHistories TaskScheduleHistory[]
  taskBaselines     TaskBaseline[]
  workLogs          WorkLog[]

  // 의존성 (Task↔Task만)
  predecessorOf Dependency[] @relation("PredecessorTask")
  successorOf   Dependency[] @relation("SuccessorTask")

  @@map("tasks")
  @@schema("project")
}

// TaskSegment = 구간별 독립 일정 + 자원
model TaskSegment {
  id              String   @id @default(cuid())
  taskId          String
  name            String
  sortOrder       Int      @default(0)
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  // 자원-기여도-진척률 (2026-06-23): derived 캐시 — 배정 1개↑ 이면 Σ(weight×progress)/Σweight 로 재계산.
  //   배정 0개(자원 미배정) 세그먼트일 때만 직접 입력 fallback.
  progressPercent Float    @default(0) // 0~100
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  task             Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignments      SegmentAssignment[]
  baselineSegments TaskBaselineSegment[]
  workLogs         WorkLog[]

  @@map("task_segments")
  @@schema("project")
}

// ─── 작업비고 (WorkLog) ──────────────────────────────────────────
model WorkLog {
  id         String                       @id @default(cuid())
  taskId     String                       @map("task_id")
  segmentId  String?                      @map("segment_id")
  embedding  Unsupported("vector(1024)")?
  embeddedAt DateTime?                    @map("embedded_at")
  authorId   String                       @map("author_id")
  authorName String                       @map("author_name")
  content    String                       @db.Text
  workedAt   DateTime                     @map("worked_at") @db.Date
  isDeleted  Boolean                      @default(false) @map("is_deleted")
  createdAt  DateTime                     @default(now()) @map("created_at")
  updatedAt  DateTime                     @updatedAt @map("updated_at")

  task    Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  segment TaskSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  @@index([taskId, isDeleted, workedAt(sort: Desc)])
  @@index([authorId, workedAt(sort: Desc)])
  @@index([segmentId])
  @@map("work_logs")
  @@schema("project")
}

// 세그먼트별 자원 배정
//   자원-모델-분리 PDCA Phase 1 (2026-05-04): polymorphic FK 컬럼 추가 (nullable)
//   Phase 2에서 데이터 이전 후 XOR CHECK constraint 추가
//   Phase 4에서 resourceId DROP
model SegmentAssignment {
  id                    String         @id @default(cuid())
  segmentId             String
  resourceId            String         // ⚠️ deprecated — Phase 4에서 drop. Phase 1~3 동안 기존 코드 호환을 위해 NOT NULL 유지
  // polymorphic FK — 셋 중 정확히 하나만 NOT NULL (Phase 2 후 XOR CHECK 추가)
  personUserId          String?        // → auth_users.id (cross-service, FK 없음)
  externalPersonId      String?        // → ExternalPerson.id
  equipmentResourceId   String?        // → EquipmentResource.id
  allocationMode        AllocationMode @default(PERCENT)
  allocationPercent     Float? // PERCENT 모드 (0~100) — 개인 가용용량 점유율
  allocationHoursPerDay Float? // HOURS 모드
  // 자원-기여도-진척률 (2026-06-23):
  contributionWeight    Float          @default(0) // 분담율 0~100 (세그먼트 내 참여자 합 권장=100)
  progressPercent       Float          @default(0) // 이 자원의 본인 진척률 0~100 (본인이 관리)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  segment   TaskSegment        @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  external  ExternalPerson?    @relation(fields: [externalPersonId], references: [id], onDelete: Cascade)
  equipment EquipmentResource? @relation(fields: [equipmentResourceId], references: [id], onDelete: Cascade)

  @@unique([segmentId, resourceId], map: "segment_assignments_segment_resource_unique")
  @@unique([segmentId, personUserId], map: "segment_assignments_segment_person_unique")
  @@unique([segmentId, externalPersonId], map: "segment_assignments_segment_external_unique")
  @@unique([segmentId, equipmentResourceId], map: "segment_assignments_segment_equipment_unique")
  @@map("segment_assignments")
  @@schema("project")
}

// ❌ TaskDependency 모델 폐기 — 통합 Dependency 모델로 대체 (4c, OQ-6)
//    백필 SQL: services/project/prisma/migrations/{ts}_milestone_redesign/migration.sql

// ─────────────────────────────────────────────
// 2. 자원 (Resource)
// ─────────────────────────────────────────────

model ResourceGroup {
  id          String              @id @default(cuid())
  name        String
  description String?
  // 자원-모델-분리 PDCA Phase 1 (2026-05-04): 그룹별 단일 종류 강제
  //   Phase 2에서 default → 기존 그룹 일괄 PERSON으로 마이그레이션
  type        ResourceGroupType   @default(PERSON)
  parentId    String?
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  parent      ResourceGroup?        @relation("ResourceGroupHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    ResourceGroup[]       @relation("ResourceGroupHierarchy")
  memberships ResourceGroupMember[]

  @@index([type])
  @@map("resource_groups")
  @@schema("project")
}

// 자원-모델-분리 PDCA Phase 1 (2026-05-04)
//   기존 PK [groupId, resourceId] 유지 — Phase 4에서 변경
//   polymorphic 컬럼은 nullable로 추가 (Phase 2 후 데이터 이전)
model ResourceGroupMember {
  groupId               String
  resourceId            String         // ⚠️ deprecated — Phase 4에서 drop
  personUserId          String?
  externalPersonId      String?
  equipmentResourceId   String?

  group     ResourceGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  // resource FK removed (Phase 4, 2026-05-13) — resourceId는 auth_users.id/external_persons.id/equipment_resources.id 중 하나의 logical pointer
  external  ExternalPerson?     @relation(fields: [externalPersonId], references: [id], onDelete: Cascade)
  equipment EquipmentResource?  @relation(fields: [equipmentResourceId], references: [id], onDelete: Cascade)

  @@id([groupId, resourceId])
  @@unique([groupId, personUserId], map: "resource_group_members_group_person_unique")
  @@unique([groupId, externalPersonId], map: "resource_group_members_group_external_unique")
  @@unique([groupId, equipmentResourceId], map: "resource_group_members_group_equipment_unique")
  @@map("resource_group_members")
  @@schema("project")
}

// ✅ Phase 5 (2026-05-13): legacy Resource 모델 전면 폐기
//    사람=auth_users, 외부=ExternalPerson, 비인력=EquipmentResource 단일 ID 모델

// 자원-모델-분리 PDCA Phase 1 (2026-05-04): 공용자산 (차량/시설)
// EQUIPMENT 타입 폐기 (2026-05-05) — 프로젝트 미연계 단순 마스터, /admin/equipment-resources에서 관리
model EquipmentResource {
  id           String        @id @default(cuid())
  name         String
  type         EquipmentType @default(VEHICLE)
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)  // 공용자산 수동 정렬 (관리화면에서 변경 → 예약 목록 반영)
  // 향후 확장 가능: serialNumber, location, calibrationCycle, lastInspectedAt, ownerDeptId 등
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  groupMemberships ResourceGroupMember[]
  assignments      SegmentAssignment[]
  reservations     EquipmentReservation[]   // 공용자산예약 (2026-05-05)

  @@index([type])
  @@index([isActive])
  @@map("equipment_resources")
  @@schema("project")
}

// 공용자산예약 (2026-05-05): 차량·시설 일자/시간 단위 예약
// - 단발 또는 반복 (recurrence JSON)
// - 같은 자원 시간 겹침은 transaction에서 차단
// - soft delete (status=CANCELED)
model EquipmentReservation {
  id                  String              @id @default(cuid())
  resourceId          String
  userId              String                                          // auth_users.id (예약자)
  title               String                                          // 사유
  description         String?
  startAt             DateTime                                        // UTC
  endAt               DateTime
  isAllDay            Boolean             @default(false)

  // 반복 (null이면 단발)
  // {freq:"DAILY"|"WEEKLY"|"MONTHLY", interval?:int, byWeekday?:["MON",...], until?:"YYYY-MM-DD", count?:int}
  recurrence          Json?
  recurrenceParentId  String?                                         // 시리즈 첫 인스턴스 id (예외 row)

  status              ReservationStatus   @default(CONFIRMED)
  cancelReason        String?
  canceledAt          DateTime?
  canceledBy          String?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  resource            EquipmentResource   @relation(fields: [resourceId], references: [id], onDelete: Restrict)

  @@index([resourceId, startAt])              // 충돌 검사 핫패스
  @@index([userId, startAt(sort: Desc)])      // 내 예약 목록
  @@index([status])
  @@index([recurrenceParentId])
  @@map("equipment_reservations")
  @@schema("project")
}

enum ReservationStatus {
  CONFIRMED
  CANCELED

  @@schema("project")
}

// 자원-모델-분리 PDCA Phase 1 (2026-05-04): 외부 자원 (외주/협력업체)
//   회사 시스템 외부 인력 — 로그인·휴가·근태·결재 X. task 배정만 가능.
model ExternalPerson {
  id            String         @id @default(cuid())
  name          String
  company       String?        // 소속 업체
  contactEmail  String?
  contactPhone  String?
  status        ExternalStatus @default(ACTIVE)
  contractStart DateTime?      @db.Date
  contractEnd   DateTime?      @db.Date
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  groupMemberships ResourceGroupMember[]
  assignments      SegmentAssignment[]

  @@index([status])
  @@index([company])
  @@map("external_persons")
  @@schema("project")
}

// ─────────────────────────────────────────────
// 3. Baseline (일정 버전 관리)
// ─────────────────────────────────────────────

model ProjectBaseline {
  id        String   @id @default(cuid())
  projectId String
  name      String
  reason    String
  createdBy String
  createdAt DateTime @default(now())

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskBaselines TaskBaseline[]

  @@map("project_baselines")
  @@schema("project")
}

model TaskBaseline {
  id                     String   @id @default(cuid())
  baselineId             String
  taskId                 String
  baselineEffectiveStart DateTime @db.Date
  baselineEffectiveEnd   DateTime @db.Date
  baselineProgress       Float

  baseline         ProjectBaseline       @relation(fields: [baselineId], references: [id], onDelete: Cascade)
  task             Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  segmentSnapshots TaskBaselineSegment[]

  @@unique([baselineId, taskId])
  @@map("task_baselines")
  @@schema("project")
}

model TaskBaselineSegment {
  id             String   @id @default(cuid())
  taskBaselineId String
  segmentId      String
  name           String
  sortOrder      Int
  startDate      DateTime @db.Date
  endDate        DateTime @db.Date
  assignments    Json // [{resourceId, name, allocationPercent, allocationHoursPerDay, mode}]

  taskBaseline TaskBaseline @relation(fields: [taskBaselineId], references: [id], onDelete: Cascade)
  segment      TaskSegment  @relation(fields: [segmentId], references: [id])

  @@map("task_baseline_segments")
  @@schema("project")
}

model TaskScheduleHistory {
  id           String     @id @default(cuid())
  taskId       String
  segmentId    String?
  changedBy    String
  changedAt    DateTime   @default(now())
  changeReason String
  changeType   ChangeType
  field        String
  oldValue     String?
  newValue     String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, changedAt(sort: Desc)])
  @@map("task_schedule_histories")
  @@schema("project")
}

// ─────────────────────────────────────────────
// 4. 협업 (Comment, Attachment, ActivityLog)
// ─────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task     Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  mentions Mention[]

  @@map("comments")
  @@schema("project")
}

model Mention {
  id        String  @id @default(cuid())
  commentId String
  userId    String
  isRead    Boolean @default(false)

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("mentions")
  @@schema("project")
}

model Attachment {
  id          String   @id @default(cuid())
  taskId      String
  fileName    String
  fileSize    Int
  mimeType    String
  storagePath String
  uploadedBy  String
  createdAt   DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("attachments")
  @@schema("project")
}

model ActivityLog {
  id          String   @id @default(cuid())
  projectId   String?
  userId      String
  action      String
  entityType  String
  entityId    String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("activity_logs")
  @@schema("project")
}

// ─────────────────────────────────────────────
// 5. 프로젝트 템플릿 시스템
// ─────────────────────────────────────────────

model ProjectTemplate {
  id              String        @id @default(cuid())
  name            String
  description     String?
  category        String
  tags            String[]
  scope           TemplateScope @default(PERSONAL)
  isRecommended   Boolean       @default(false)
  usageCount      Int           @default(0)
  sourceProjectId String?
  createdBy       String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  templateTasks TemplateTask[]

  @@map("project_templates")
  @@schema("project")
}

model TemplateTask {
  id          String  @id @default(cuid())
  templateId  String
  parentId    String? // WBS 계층 (상위 템플릿 태스크)
  name        String
  description String?
  // ❌ milestoneGroup 폐기 — Milestone 그룹 의미 폐기 (3a, Plan)
  sortOrder   Int     @default(0)

  template        ProjectTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent          TemplateTask?        @relation("TemplateTaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        TemplateTask[]       @relation("TemplateTaskHierarchy")
  segments        TemplateSegment[]
  predecessorDeps TemplateDependency[] @relation("templatePredecessor")
  successorDeps   TemplateDependency[] @relation("templateSuccessor")

  @@map("template_tasks")
  @@schema("project")
}

model TemplateSegment {
  id             String @id @default(cuid())
  templateTaskId String
  name           String
  sortOrder      Int    @default(0)
  dayOffsetStart Int
  dayOffsetEnd   Int

  templateTask TemplateTask         @relation(fields: [templateTaskId], references: [id], onDelete: Cascade)
  assignments  TemplateAssignment[]

  @@map("template_segments")
  @@schema("project")
}

model TemplateAssignment {
  id                    String         @id @default(cuid())
  templateSegmentId     String
  resourceRole          String?
  resourceId            String?
  allocationMode        AllocationMode @default(PERCENT)
  allocationPercent     Float?
  allocationHoursPerDay Float?

  templateSegment TemplateSegment @relation(fields: [templateSegmentId], references: [id], onDelete: Cascade)

  @@map("template_assignments")
  @@schema("project")
}

model TemplateDependency {
  id                        String         @id @default(cuid())
  predecessorTemplateTaskId String
  successorTemplateTaskId   String
  type                      DependencyType @default(FS)
  lagDays                   Int            @default(0)

  predecessorTask TemplateTask @relation("templatePredecessor", fields: [predecessorTemplateTaskId], references: [id], onDelete: Cascade)
  successorTask   TemplateTask @relation("templateSuccessor", fields: [successorTemplateTaskId], references: [id], onDelete: Cascade)

  @@unique([predecessorTemplateTaskId, successorTemplateTaskId])
  @@map("template_dependencies")
  @@schema("project")
}

// ─────────────────────────────────────────────
// 6. 프로젝트 그룹 계층 (최대 2단계)
// ─────────────────────────────────────────────

model ProjectGroup {
  id            String    @id @default(cuid())
  name          String
  type          GroupType @default(CUSTOM)
  level         Int // 1 또는 2
  parentGroupId String?
  color         String    @default("#6B7280")
  sortOrder     Int       @default(0)
  description   String?
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  parentGroup ProjectGroup?            @relation("GroupHierarchy", fields: [parentGroupId], references: [id])
  childGroups ProjectGroup[]           @relation("GroupHierarchy")
  memberships ProjectGroupMembership[]

  @@map("project_groups")
  @@schema("project")
}

model ProjectGroupMembership {
  id           String   @id @default(cuid())
  groupId      String
  projectId    String
  displayOrder Int      @default(0)
  addedBy      String
  createdAt    DateTime @default(now())

  group   ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([groupId, projectId])
  @@map("project_group_memberships")
  @@schema("project")
}

// ─────────────────────────────────────────────
// 7. 대시보드 설정 (지휘센터 + 개인)
// ─────────────────────────────────────────────

model DashboardConfig {
  id               String   @id @default(cuid())
  userId           String   @unique
  visibleGroupIds  String[] // 표시할 그룹 ID 목록
  pinnedProjectIds String[] // 상단 고정 프로젝트
  issueFilter      String   @default("ALL") // ALL | CRITICAL | WARNING
  timelineRange    Int      @default(7) // ±N일
  compactView      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("dashboard_configs")
  @@schema("project")
}

model IssueThresholdConfig {
  id                      String   @id @default(cuid())
  delayWarningDays        Int      @default(3)
  delayCriticalDays       Int      @default(7)
  progressBehindWarning   Float    @default(10.0) // %
  progressBehindCritical  Float    @default(20.0) // %
  resourceOverloadWarning Float    @default(90.0) // %
  updatedBy               String
  updatedAt               DateTime @updatedAt

  @@map("issue_threshold_configs")
  @@schema("project")
}

// ─────────────────────────────────────────────
// 프로젝트 폴더 (트리 구조)
// ─────────────────────────────────────────────

model ProjectFolder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  sortOrder Int      @default(0)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ProjectFolder?      @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ProjectFolder[]     @relation("FolderTree")
  projects ProjectFolderItem[]

  @@map("project_folders")
  @@schema("project")
}

model ProjectFolderItem {
  id        String @id @default(cuid())
  folderId  String
  projectId String
  sortOrder Int    @default(0)

  folder ProjectFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([folderId, projectId])
  @@map("project_folder_items")
  @@schema("project")
}
