generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["equipment"]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum AssetStatus {
  AVAILABLE
  IN_OPERATION
  DEPLOYED
  IN_MAINTENANCE
  BROKEN
  RETIRED

  @@schema("equipment")
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  CALIBRATION
  UPGRADE
  TRAINING
  STANDBY

  @@schema("equipment")
}

enum ScheduleType {
  PROJECT
  MAINTENANCE
  CALIBRATION
  TRAINING
  STANDBY

  @@schema("equipment")
}

enum DeploymentStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 1. Category (장비 종류 + 센서 종류 통합)
// ─────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  type        String   // "EQUIPMENT" | "SENSOR"
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment Equipment[]
  sensors   Sensor[]

  @@unique([name, type])
  @@map("categories")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 2. Equipment (장비: USV, AUV 등)
// ─────────────────────────────────────────────

model Equipment {
  id           String      @id @default(cuid())
  categoryId   String
  name         String
  serialNumber String      @unique
  manufacturer String?
  model        String?
  acquiredAt   DateTime?
  status       AssetStatus @default(AVAILABLE)
  description  String?
  imageUrl     String?
  metadata     Json?
  createdBy    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  category            Category              @relation(fields: [categoryId], references: [id])
  components          EquipmentComponent[]
  maintenanceRecords  MaintenanceRecord[]
  schedules           AssetSchedule[]
  sensorCompatibility SensorCompatibility[]
  deployments         Deployment[]
  repairOrders        RepairOrder[]

  @@map("equipment")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 2-1. EquipmentComponent (장비 구성요소: 엔진, GPS 등)
// ─────────────────────────────────────────────

model EquipmentComponent {
  id          String   @id @default(cuid())
  equipmentId String
  name        String
  spec        String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@map("equipment_components")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 3. Sensor (독립 자산 풀)
// ─────────────────────────────────────────────

model Sensor {
  id                      String      @id @default(cuid())
  categoryId              String
  name                    String
  serialNumber            String      @unique
  manufacturer            String?
  model                   String?
  acquiredAt              DateTime?
  status                  AssetStatus @default(AVAILABLE)
  description             String?
  calibrationIntervalDays Int?
  lastCalibratedAt        DateTime?
  nextCalibrationDue      DateTime?
  currentLocation         String?     @default("창고")
  currentEquipmentId      String?
  currentDeploymentId     String?
  metadata                Json?
  createdBy               String
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  category            Category              @relation(fields: [categoryId], references: [id])
  maintenanceRecords  MaintenanceRecord[]
  schedules           AssetSchedule[]
  sensorCompatibility SensorCompatibility[]
  deploymentSensors   DeploymentSensor[]
  repairOrders        RepairOrder[]

  @@map("sensors")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 4. SensorCompatibility (장비-센서 호환성 N:M)
// ─────────────────────────────────────────────

model SensorCompatibility {
  id          String   @id @default(cuid())
  equipmentId String
  sensorId    String
  notes       String?
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sensor    Sensor    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, sensorId])
  @@map("sensor_compatibility")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 5. MaintenanceRecord (정비 이력 — 장비+센서 공용)
// ─────────────────────────────────────────────

model MaintenanceRecord {
  id            String          @id @default(cuid())
  equipmentId   String?
  sensorId      String?
  type          MaintenanceType
  title         String
  description   String?
  performedBy   String?
  performedAt   DateTime
  completedAt   DateTime?
  cost          Decimal?        @db.Decimal(12, 2)
  durationHours Float?
  replacedParts String?
  attachmentUrls Json?
  notes         String?
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  equipment Equipment? @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sensor    Sensor?    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([sensorId])
  @@map("maintenance_records")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 6. AssetSchedule (운영 일정 — 장비+센서 공용)
// ─────────────────────────────────────────────

model AssetSchedule {
  id           String       @id @default(cuid())
  equipmentId  String?
  sensorId     String?
  type         ScheduleType @default(MAINTENANCE)
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime
  projectId    String?
  projectName  String?
  deploymentId String?
  createdBy    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  equipment Equipment? @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sensor    Sensor?    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([equipmentId, startDate, endDate])
  @@index([sensorId, startDate, endDate])
  @@index([projectId])
  @@map("asset_schedules")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 7. Deployment (투입 구성)
// ─────────────────────────────────────────────

model Deployment {
  id           String           @id @default(cuid())
  equipmentId  String?
  projectId    String
  projectName  String
  taskId       String?
  taskName     String?
  status       DeploymentStatus @default(PLANNED)
  startDate    DateTime
  endDate      DateTime?
  configParams Json?
  notes        String?
  createdBy    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  equipment Equipment?         @relation(fields: [equipmentId], references: [id])
  sensors   DeploymentSensor[]

  @@index([equipmentId])
  @@index([projectId])
  @@index([taskId])
  @@map("deployments")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 8. DeploymentSensor (투입 시 센서 체크아웃)
// ─────────────────────────────────────────────

model DeploymentSensor {
  id           String    @id @default(cuid())
  deploymentId String
  sensorId     String
  configParams Json?
  checkedOutAt DateTime  @default(now())
  returnedAt   DateTime?
  notes        String?

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  sensor     Sensor     @relation(fields: [sensorId], references: [id])

  @@index([deploymentId])
  @@index([sensorId])
  @@map("deployment_sensors")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 9. DeploymentTemplate (투입 구성 템플릿)
// ─────────────────────────────────────────────

model DeploymentTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  categoryId   String?
  sensorConfig Json
  isPublic     Boolean  @default(false)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("deployment_templates")
  @@schema("equipment")
}

// ═══════════════════════════════════════════════
// 수리관리 (Repair & AS Management) — Enums
// ═══════════════════════════════════════════════

enum RepairOrderType {
  REPAIR
  DELIVERY

  @@schema("equipment")
}

enum RepairOrderStatus {
  RECEIVED
  INSPECTING_1ST
  QUOTED
  APPROVED
  REPAIRING
  SHIPPED_TO_MFG
  RECEIVED_FROM_MFG
  INSPECTING_2ND
  COMPLETED
  CLOSED
  CANCELLED

  @@schema("equipment")
}

enum RepairPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@schema("equipment")
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED

  @@schema("equipment")
}

enum ShipmentDirection {
  OUTBOUND
  INBOUND

  @@schema("equipment")
}

enum ShipmentStatus {
  PREPARING
  SHIPPED
  IN_TRANSIT
  DELIVERED

  @@schema("equipment")
}

enum CostType {
  DIRECT_EXPENSE
  LABOR
  OVERSEAS_SHIPPING
  PARTS
  OTHER

  @@schema("equipment")
}

enum PartTransactionType {
  IN
  OUT
  ADJUST

  @@schema("equipment")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  PO_RECEIVED
  PO_CANCELLED

  @@schema("equipment")
}

// ═══════════════════════════════════════════════
// 수리관리 — Models
// ═══════════════════════════════════════════════

// ─── R-1. Customer (고객) ─────────────────────

model Customer {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?
  department    String?
  phone         String?
  email         String?
  address       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assets       CustomerAsset[]
  repairOrders RepairOrder[]

  @@map("customers")
  @@schema("equipment")
}

// ─── R-2. CustomerAsset (고객 보유 자산) ──────

model CustomerAsset {
  id             String    @id @default(cuid())
  customerId     String
  assetType      String
  name           String
  serialNumber   String?
  manufacturer   String?
  model          String?
  manufacturedAt String?
  soldAt         DateTime?
  warrantyExpiry DateTime?
  otInventoryNo  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  repairOrders RepairOrder[]

  @@index([customerId])
  @@index([serialNumber])
  @@map("customer_assets")
  @@schema("equipment")
}

// ─── R-3. RepairOrder (AS 접수) ──────────────

model RepairOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  orderType        RepairOrderType   @default(REPAIR)
  status           RepairOrderStatus @default(RECEIVED)
  priority         RepairPriority    @default(NORMAL)

  customerId       String?
  customerAssetId  String?
  equipmentId      String?
  sensorId         String?

  techStatus       String?
  salesStatus      String?

  currentLocation  String?
  symptom          String?
  otInventoryNo    String?

  diagnosis1st     String?
  inspector1stId   String?
  inspector1stName String?

  needsMfgRepair   Boolean          @default(false)
  mfgReferenceNo   String?

  diagnosis2nd     String?
  inspector2ndId   String?
  inspector2ndName String?

  repairDetails    String?
  isWarranty       Boolean          @default(false)

  receivedBy       String?
  assigneeId       String?
  assigneeName     String?

  receivedAt       DateTime         @default(now())
  estimatedDays    Int?
  completedAt      DateTime?
  closedAt         DateTime?

  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  customer         Customer?          @relation(fields: [customerId], references: [id])
  customerAsset    CustomerAsset?     @relation(fields: [customerAssetId], references: [id])
  equipment        Equipment?         @relation(fields: [equipmentId], references: [id])
  sensor           Sensor?            @relation(fields: [sensorId], references: [id])
  inspectionReport InspectionReport?
  costs            RepairCost[]
  quotes           RepairQuote[]
  shipments        Shipment[]
  usedParts        PartTransaction[]

  @@index([customerId])
  @@index([status])
  @@index([receivedAt])
  @@index([orderNumber])
  @@map("repair_orders")
  @@schema("equipment")
}

// ─── R-4. InspectionReport (점검보고서) ──────

model InspectionReport {
  id               String   @id @default(cuid())
  repairOrderId    String   @unique
  reportNumber     String?
  equipmentHistory Json?
  customerInfo     Json?
  inspectorId      String?
  inspectorName    String?
  symptom          String?
  inspectionSteps  Json?
  result           String?
  needsMfgRepair   Boolean  @default(false)
  mfgRepairReason  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@map("inspection_reports")
  @@schema("equipment")
}

// ─── R-5. RepairCost (비용 항목) ─────────────

model RepairCost {
  id            String   @id @default(cuid())
  repairOrderId String
  costType      CostType
  description   String?
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("KRW")
  exchangeRate  Decimal? @db.Decimal(10, 4)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@index([repairOrderId])
  @@map("repair_costs")
  @@schema("equipment")
}

// ─── R-6. RepairQuote (견적) ─────────────────

model RepairQuote {
  id            String      @id @default(cuid())
  repairOrderId String
  quoteNumber   String?
  laborCost     Decimal?    @db.Decimal(12, 2)
  partsCost     Decimal?    @db.Decimal(12, 2)
  shippingCost  Decimal?    @db.Decimal(12, 2)
  totalAmount   Decimal     @db.Decimal(12, 2)
  currency      String      @default("KRW")
  exchangeRate  Decimal?    @db.Decimal(10, 4)
  status        QuoteStatus @default(DRAFT)
  validUntil    DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])
  items       QuoteItem[]

  @@index([repairOrderId])
  @@map("repair_quotes")
  @@schema("equipment")
}

// ─── R-7. QuoteItem (견적 항목) ──────────────

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  partId      String?

  quote RepairQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  part  Part?       @relation(fields: [partId], references: [id])

  @@index([quoteId])
  @@map("quote_items")
  @@schema("equipment")
}

// ─── R-8. Part (교체 부품) ───────────────────

model Part {
  id               String   @id @default(cuid())
  partNumber       String   @unique
  name             String
  manufacturer     String?
  category         String?
  unitPrice        Decimal? @db.Decimal(12, 2)
  currency         String   @default("KRW")
  stockQuantity    Int      @default(0)
  minStockLevel    Int      @default(0)
  leadTimeDays     Int?
  location         String?
  compatibleAssets Json?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions  PartTransaction[]
  quoteItems    QuoteItem[]
  purchaseItems PurchaseOrderItem[]

  @@map("parts")
  @@schema("equipment")
}

// ─── R-9. PartTransaction (부품 입출고) ──────

model PartTransaction {
  id              String              @id @default(cuid())
  partId          String
  type            PartTransactionType
  quantity        Int
  reason          String?
  repairOrderId   String?
  purchaseOrderId String?
  performedBy     String?
  performedAt     DateTime            @default(now())

  part        Part         @relation(fields: [partId], references: [id])
  repairOrder RepairOrder? @relation(fields: [repairOrderId], references: [id])

  @@index([partId])
  @@index([repairOrderId])
  @@map("part_transactions")
  @@schema("equipment")
}

// ─── R-10. PurchaseOrder (부품 발주) ─────────

model PurchaseOrder {
  id               String              @id @default(cuid())
  orderNumber      String              @unique
  supplier         String
  status           PurchaseOrderStatus @default(DRAFT)
  orderedAt        DateTime?
  expectedDelivery DateTime?
  totalAmount      Decimal?            @db.Decimal(12, 2)
  currency         String              @default("KRW")
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  items PurchaseOrderItem[]

  @@map("purchase_orders")
  @@schema("equipment")
}

// ─── R-11. PurchaseOrderItem (발주 항목) ─────

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  partId           String
  quantity         Int
  receivedQuantity Int     @default(0)
  unitPrice        Decimal @db.Decimal(12, 2)
  amount           Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  part          Part          @relation(fields: [partId], references: [id])

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
  @@schema("equipment")
}

// ─── R-12. Shipment (제조사 발송/입고) ───────

model Shipment {
  id             String            @id @default(cuid())
  repairOrderId  String
  direction      ShipmentDirection
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  receivedAt     DateTime?
  shippingCost   Decimal?          @db.Decimal(12, 2)
  status         ShipmentStatus    @default(PREPARING)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@index([repairOrderId])
  @@map("shipments")
  @@schema("equipment")
}
