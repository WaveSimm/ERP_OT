generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["equipment"]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum AssetStatus {
  AVAILABLE
  IN_OPERATION
  DEPLOYED
  IN_MAINTENANCE
  BROKEN
  RETIRED

  @@schema("equipment")
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  CALIBRATION
  UPGRADE
  TRAINING
  STANDBY

  @@schema("equipment")
}

enum ScheduleType {
  PROJECT
  MAINTENANCE
  CALIBRATION
  TRAINING
  STANDBY

  @@schema("equipment")
}

enum DeploymentStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 0. StorageLocation (보관위치 — 창고/고객사)
// ─────────────────────────────────────────────

enum LocationType {
  WAREHOUSE
  CUSTOMER

  @@schema("equipment")
}

model StorageLocation {
  id          String       @id @default(cuid())
  name        String       @unique
  type        LocationType @default(WAREHOUSE)
  description String?
  sortOrder   Int          @default(0) @map("sort_order")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  inventoryLocations InventoryItemLocation[]

  @@index([type])
  @@map("storage_locations")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 1. Category (장비 종류 + 센서 종류 통합)
// ─────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  type        String   // "EQUIPMENT" | "SENSOR"
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment Equipment[]
  sensors   Sensor[]

  @@unique([name, type])
  @@map("categories")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 2. Equipment (장비: USV, AUV 등)
// ─────────────────────────────────────────────

model Equipment {
  id           String      @id @default(cuid())
  categoryId   String
  name         String
  serialNumber String      @unique
  manufacturer String?
  model        String?
  acquiredAt   DateTime?
  status       AssetStatus @default(AVAILABLE)
  description  String?
  imageUrl     String?
  metadata     Json?
  createdBy    String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  category            Category              @relation(fields: [categoryId], references: [id])
  components          EquipmentComponent[]
  maintenanceRecords  MaintenanceRecord[]
  schedules           AssetSchedule[]
  sensorCompatibility SensorCompatibility[]
  deployments         Deployment[]
  repairOrders        RepairOrder[]

  @@map("equipment")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 2-1. EquipmentComponent (장비 구성요소: 엔진, GPS 등)
// ─────────────────────────────────────────────

model EquipmentComponent {
  id          String   @id @default(cuid())
  equipmentId String
  name        String
  spec        String?
  notes       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@map("equipment_components")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 3. Sensor (독립 자산 풀)
// ─────────────────────────────────────────────

model Sensor {
  id                      String      @id @default(cuid())
  categoryId              String
  name                    String
  serialNumber            String      @unique
  manufacturer            String?
  model                   String?
  acquiredAt              DateTime?
  status                  AssetStatus @default(AVAILABLE)
  description             String?
  calibrationIntervalDays Int?
  lastCalibratedAt        DateTime?
  nextCalibrationDue      DateTime?
  currentLocation         String?     @default("창고")
  currentEquipmentId      String?
  currentDeploymentId     String?
  metadata                Json?
  createdBy               String
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  category            Category              @relation(fields: [categoryId], references: [id])
  maintenanceRecords  MaintenanceRecord[]
  schedules           AssetSchedule[]
  sensorCompatibility SensorCompatibility[]
  deploymentSensors   DeploymentSensor[]
  repairOrders        RepairOrder[]

  @@map("sensors")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 4. SensorCompatibility (장비-센서 호환성 N:M)
// ─────────────────────────────────────────────

model SensorCompatibility {
  id          String   @id @default(cuid())
  equipmentId String
  sensorId    String
  notes       String?
  createdAt   DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sensor    Sensor    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, sensorId])
  @@map("sensor_compatibility")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 5. MaintenanceRecord (정비 이력 — 장비+센서 공용)
// ─────────────────────────────────────────────

model MaintenanceRecord {
  id            String          @id @default(cuid())
  equipmentId   String?
  sensorId      String?
  type          MaintenanceType
  title         String
  description   String?
  performedBy   String?
  performedAt   DateTime
  completedAt   DateTime?
  cost          Decimal?        @db.Decimal(12, 2)
  durationHours Float?
  replacedParts String?
  attachmentUrls Json?
  notes         String?
  createdBy     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  equipment Equipment? @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sensor    Sensor?    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([sensorId])
  @@map("maintenance_records")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 6. AssetSchedule (운영 일정 — 장비+센서 공용)
// ─────────────────────────────────────────────

model AssetSchedule {
  id           String       @id @default(cuid())
  equipmentId  String?
  sensorId     String?
  type         ScheduleType @default(MAINTENANCE)
  title        String
  description  String?
  startDate    DateTime
  endDate      DateTime
  projectId    String?
  projectName  String?
  deploymentId String?
  createdBy    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  equipment Equipment? @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  sensor    Sensor?    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([equipmentId, startDate, endDate])
  @@index([sensorId, startDate, endDate])
  @@index([projectId])
  @@map("asset_schedules")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 7. Deployment (투입 구성)
// ─────────────────────────────────────────────

model Deployment {
  id           String           @id @default(cuid())
  equipmentId  String?
  projectId    String
  projectName  String
  taskId       String?
  taskName     String?
  status       DeploymentStatus @default(PLANNED)
  startDate    DateTime
  endDate      DateTime?
  configParams Json?
  notes        String?
  createdBy    String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  equipment Equipment?         @relation(fields: [equipmentId], references: [id])
  sensors   DeploymentSensor[]

  @@index([equipmentId])
  @@index([projectId])
  @@index([taskId])
  @@map("deployments")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 8. DeploymentSensor (투입 시 센서 체크아웃)
// ─────────────────────────────────────────────

model DeploymentSensor {
  id           String    @id @default(cuid())
  deploymentId String
  sensorId     String
  configParams Json?
  checkedOutAt DateTime  @default(now())
  returnedAt   DateTime?
  notes        String?

  deployment Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  sensor     Sensor     @relation(fields: [sensorId], references: [id])

  @@index([deploymentId])
  @@index([sensorId])
  @@map("deployment_sensors")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// 9. DeploymentTemplate (투입 구성 템플릿)
// ─────────────────────────────────────────────

model DeploymentTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  categoryId   String?
  sensorConfig Json
  isPublic     Boolean  @default(false)
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("deployment_templates")
  @@schema("equipment")
}

// ═══════════════════════════════════════════════
// 수리관리 (Repair & AS Management) — Enums
// ═══════════════════════════════════════════════

enum RepairOrderType {
  REPAIR
  DELIVERY

  @@schema("equipment")
}

enum RepairOrderStatus {
  RECEIVED
  INSPECTING_1ST
  QUOTED
  APPROVED
  REPAIRING
  SHIPPED_TO_MFG
  RECEIVED_FROM_MFG
  INSPECTING_2ND
  COMPLETED
  NO_FAULT          // 정상 (점검 결과 이상 없음)
  NO_REPAIR         // 수리안함 (고장 확인됐으나 수리하지 않음)
  CLOSED
  CANCELLED

  @@schema("equipment")
}

// 1차·2차 점검 판단 — 점검 결과에 따른 조치 결정
enum InspectionDecision {
  IN_HOUSE_REPAIR   // 본사수리
  SEND_TO_MFG       // 제조사발송
  NORMAL            // 정상
  KEEP_AS_IS        // 수리안함

  @@schema("equipment")
}

enum RepairPriority {
  LOW
  NORMAL
  HIGH
  URGENT

  @@schema("equipment")
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED

  @@schema("equipment")
}

enum ShipmentDirection {
  OUTBOUND
  INBOUND

  @@schema("equipment")
}

enum ShipmentStatus {
  PREPARING
  SHIPPED
  IN_TRANSIT
  DELIVERED

  @@schema("equipment")
}

enum CostType {
  DIRECT_EXPENSE
  LABOR
  OVERSEAS_SHIPPING
  PARTS
  OTHER

  @@schema("equipment")
}

enum PartTransactionType {
  IN
  OUT
  ADJUST

  @@schema("equipment")
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  PO_RECEIVED
  PO_CANCELLED

  @@schema("equipment")
}

// ═══════════════════════════════════════════════
// 수리관리 — Models
// ═══════════════════════════════════════════════

// ─── R-1. Customer (고객) ─────────────────────

model Customer {
  id            String   @id @default(cuid())
  name          String
  businessNo    String?                          // 사업자등록번호
  contactPerson String?                          // (레거시) 단일 담당자 — contacts로 이전
  department    String?
  phone         String?                          // 대표전화번호
  email         String?
  address       String?                          // 대표주소
  address2      String?                          // 2차 주소
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assets       CustomerAsset[]
  repairOrders RepairOrder[]
  contacts     CustomerContact[]
  bundleShipments BundleShipment[]

  @@map("customers")
  @@schema("equipment")
}

// ─── R-1b. CustomerContact (고객 담당자) ──────

model CustomerContact {
  id           String   @id @default(cuid())
  customerId   String
  name         String                            // 담당자 이름
  department   String?                           // 부서
  position     String?                           // 직위
  phone        String?
  email        String?
  isPrimary    Boolean  @default(false)           // 주담당자 여부
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_contacts")
  @@schema("equipment")
}

// ─── R-2. CustomerAsset (고객 보유 자산) ──────

model CustomerAsset {
  id             String    @id @default(cuid())
  customerId     String
  assetType      String
  name           String
  serialNumber   String?
  manufacturer   String?
  model          String?
  manufacturedAt String?
  soldAt         DateTime?
  warrantyExpiry DateTime?
  otInventoryNo  String?
  // v1.6 신규 (2026-05-13): Bundle 추적
  bundleShipmentId String?  @map("bundle_shipment_id")
  bundleRole       String?  @map("bundle_role")          // "CTD 센서", "Battery 1번"
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer       Customer        @relation(fields: [customerId], references: [id])
  bundleShipment BundleShipment? @relation(fields: [bundleShipmentId], references: [id])
  bundleShipmentItems BundleShipmentItem[]
  repairOrders   RepairOrder[]

  @@index([customerId])
  @@index([serialNumber])
  @@index([bundleShipmentId])
  @@map("customer_assets")
  @@schema("equipment")
}

// ─── R-3. RepairOrder (AS 접수) ──────────────

model RepairOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  orderType        RepairOrderType   @default(REPAIR)
  status           RepairOrderStatus @default(RECEIVED)
  priority         RepairPriority    @default(NORMAL)

  customerId           String?
  customerAssetId      String?
  customerContactName  String?                    // 고객사 담당자 이름
  customerContactPhone String?                    // 고객사 담당자 연락처
  equipmentId          String?
  sensorId             String?

  // 제품 정보 (FK 미연결 시 직접 입력)
  productName      String?                          // 제품명
  productMaker     String?                          // 제작사
  productSerial    String?                          // S/N

  techStatus       String?
  salesStatus      String?

  currentLocation  String?
  symptom          String?
  otInventoryNo    String?

  diagnosis1st     String?
  inspector1stId   String?
  inspector1stName String?
  decision1st      InspectionDecision?
  decision1stReason String?

  needsMfgRepair   Boolean          @default(false)  // legacy — decision1st=SEND_TO_MFG로 대체
  mfgReferenceNo   String?

  // 제조사 견적 · 발주
  mfgQuoteNumber   String?
  mfgQuoteAmount   Decimal?         @db.Decimal(12, 2)
  mfgQuoteCurrency String?          @default("KRW")
  mfgPoNumber      String?
  mfgPoAmount      Decimal?         @db.Decimal(12, 2)
  mfgPoCurrency    String?          @default("KRW")

  diagnosis2nd     String?
  inspector2ndId   String?
  inspector2ndName String?
  decision2nd      InspectionDecision?
  decision2ndReason String?

  repairDetails    String?                          // 본사 수리 내용 (IN_HOUSE_REPAIR 케이스)
  // 제조사 수리 phase (SEND_TO_MFG 케이스, 2026-05-06 v1.2)
  mfgInspectionResult  String?                      // 제조사 측 점검 결과
  mfgRepairDetails     String?                      // 제조사 수리 내용
  isWarranty       Boolean          @default(false)

  receivedBy       String?
  assigneeId       String?
  assigneeName     String?
  assigneePhone    String?
  shippingAssigneeName String?                         // 운송/발주 담당자

  // 공정 날짜
  stockedAt        DateTime?                          // 창고 입고일
  handedToTechAt   DateTime?                          // 기술팀 인계일
  quoteReceivedAt  DateTime?                          // 견적(Quote) 수신일
  quoteApprovedAt  DateTime?                          // 견적 확정일
  poIssuedAt       DateTime?                          // 발주(PO) 발행일
  deliveryDueAt    DateTime?                          // 납기

  receivedAt       DateTime         @default(now())
  requestedDate    DateTime?
  estimatedDays    Int?
  completedAt      DateTime?
  closedAt         DateTime?

  laborDays        Decimal?         @db.Decimal(6, 1)
  directCost       Decimal?         @db.Decimal(12, 2)
  overseasShipDate DateTime?
  returnDate       DateTime?
  linkUrl          String?

  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  customer         Customer?          @relation(fields: [customerId], references: [id])
  customerAsset    CustomerAsset?     @relation(fields: [customerAssetId], references: [id])
  equipment        Equipment?         @relation(fields: [equipmentId], references: [id])
  sensor           Sensor?            @relation(fields: [sensorId], references: [id])
  inspectionReport InspectionReport?
  costs            RepairCost[]
  quotes           RepairQuote[]
  shipments        Shipment[]
  usedParts        PartTransaction[]

  @@index([customerId])
  @@index([status])
  @@index([receivedAt])
  @@index([orderNumber])
  @@map("repair_orders")
  @@schema("equipment")
}

// ─── R-4. InspectionReport (점검보고서) ──────

model InspectionReport {
  id               String   @id @default(cuid())
  repairOrderId    String   @unique
  reportNumber     String?
  equipmentHistory Json?
  customerInfo     Json?
  inspectorId      String?
  inspectorName    String?
  symptom          String?
  inspectionSteps  Json?                          // ⚠ deprecated (2026-05-06 v1.2): phase 기반 phaseAttachments로 대체. 기존 데이터 read-only 보존.
  phaseAttachments Json?                          // phase별 첨부 ({first:[],inHouse:[],mfg:[],second:[]}, 2026-05-06 v1.2)
  result           String?
  decision         InspectionDecision?          // 1차점검 판단(필수 권장)
  decisionReason   String?                       // 판단 사유
  needsMfgRepair   Boolean  @default(false)      // legacy
  mfgRepairReason  String?                       // legacy
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@map("inspection_reports")
  @@schema("equipment")
}

// ─── R-5. RepairCost (비용 항목) ─────────────

model RepairCost {
  id            String   @id @default(cuid())
  repairOrderId String
  costType      CostType
  description   String?
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("KRW")
  exchangeRate  Decimal? @db.Decimal(10, 4)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@index([repairOrderId])
  @@map("repair_costs")
  @@schema("equipment")
}

// ─── R-6. RepairQuote (견적) ─────────────────

model RepairQuote {
  id            String      @id @default(cuid())
  repairOrderId String
  quoteNumber   String?
  laborCost     Decimal?    @db.Decimal(12, 2)
  partsCost     Decimal?    @db.Decimal(12, 2)
  shippingCost  Decimal?    @db.Decimal(12, 2)
  totalAmount   Decimal     @db.Decimal(12, 2)
  currency      String      @default("KRW")
  exchangeRate  Decimal?    @db.Decimal(10, 4)
  status        QuoteStatus @default(DRAFT)
  validUntil    DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])
  items       QuoteItem[]

  @@index([repairOrderId])
  @@map("repair_quotes")
  @@schema("equipment")
}

// ─── R-7. QuoteItem (견적 항목) ──────────────

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  amount      Decimal @db.Decimal(12, 2)
  partId      String?

  quote RepairQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  part  Part?       @relation(fields: [partId], references: [id])

  @@index([quoteId])
  @@map("quote_items")
  @@schema("equipment")
}

// ─── R-8. Part (교체 부품) ───────────────────

model Part {
  id               String   @id @default(cuid())
  partNumber       String   @unique
  name             String
  manufacturer     String?
  category         String?
  unitPrice        Decimal? @db.Decimal(12, 2)
  currency         String   @default("KRW")
  stockQuantity    Int      @default(0)
  minStockLevel    Int      @default(0)
  leadTimeDays     Int?
  location         String?
  compatibleAssets Json?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions  PartTransaction[]
  quoteItems    QuoteItem[]
  purchaseItems PurchaseOrderItem[]

  @@map("parts")
  @@schema("equipment")
}

// ─── R-9. PartTransaction (부품 입출고) ──────

model PartTransaction {
  id              String              @id @default(cuid())
  partId          String
  type            PartTransactionType
  quantity        Int
  reason          String?
  repairOrderId   String?
  purchaseOrderId String?
  performedBy     String?
  performedAt     DateTime            @default(now())

  part        Part         @relation(fields: [partId], references: [id])
  repairOrder RepairOrder? @relation(fields: [repairOrderId], references: [id])

  @@index([partId])
  @@index([repairOrderId])
  @@map("part_transactions")
  @@schema("equipment")
}

// ─── R-10. PurchaseOrder (부품 발주) ─────────

model PurchaseOrder {
  id               String              @id @default(cuid())
  orderNumber      String              @unique
  supplier         String
  status           PurchaseOrderStatus @default(DRAFT)
  orderedAt        DateTime?
  expectedDelivery DateTime?
  totalAmount      Decimal?            @db.Decimal(12, 2)
  currency         String              @default("KRW")
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  items PurchaseOrderItem[]

  @@map("purchase_orders")
  @@schema("equipment")
}

// ─── R-11. PurchaseOrderItem (발주 항목) ─────

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  partId           String
  productMasterId  String? @map("product_master_id")   // v1.6 신규
  variantId        String? @map("variant_id")           // v1.6 신규
  quantity         Int
  receivedQuantity Int     @default(0)
  unitPrice        Decimal @db.Decimal(12, 2)
  amount           Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  part          Part            @relation(fields: [partId], references: [id])
  productMaster ProductMaster?  @relation("PMPurchaseItems", fields: [productMasterId], references: [id])
  variant       ProductVariant? @relation("PVPurchaseItems", fields: [variantId], references: [id])

  @@index([purchaseOrderId])
  @@index([variantId])
  @@map("purchase_order_items")
  @@schema("equipment")
}

// ─── R-12. Shipment (제조사 발송/입고) ───────

model Shipment {
  id             String            @id @default(cuid())
  repairOrderId  String
  direction      ShipmentDirection
  rmaNumber      String?
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?
  receivedAt     DateTime?
  shippingCost   Decimal?          @db.Decimal(12, 2)
  status         ShipmentStatus    @default(PREPARING)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@index([repairOrderId])
  @@map("shipments")
  @@schema("equipment")
}

// ═══════════════════════════════════════════════
// 구매 · 재고 · 결재 (Phase 1~)
// ═══════════════════════════════════════════════

// ─── Enums ────────────────────────────────────

// ─── Phase 3: 재고 관련 Enum ──────────────────

enum InventoryCategory {
  IN_TRANSIT
  PRODUCT
  RAW_MATERIAL
  PREV_PRODUCT
  PREV_RAW_MATERIAL

  @@schema("equipment")
}

enum InventoryStatus {
  IN_STOCK
  RELEASED
  IN_REPAIR

  @@schema("equipment")
}

enum InventoryTrackingMode {
  INDIVIDUAL
  BULK

  @@schema("equipment")
}

enum InventoryTransactionType {
  PURCHASE
  TRANSFER
  RELEASE
  RETURN

  @@schema("equipment")
}

enum InventorySourceType {
  OVERSEAS_ORDER
  EXPENSE_REQUEST

  @@schema("equipment")
}

enum AssetCostType {
  AS
  UPGRADE
  PARTS_ADDITION
  MODULE_ADDITION
  REPAIR
  OTHER

  @@schema("equipment")
}

// ─── Phase 1 Enum ──────────────────────────────

enum OrderCurrency {
  EUR
  GBP
  USD
  KRW

  @@schema("equipment")
}

enum OrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ORDERED
  IN_PRODUCTION
  SHIPPED
  CUSTOMS
  PARTIALLY_RECEIVED
  ARRIVED
  CLOSED

  @@schema("equipment")
}

enum OrderItemReceiptStatus {
  PENDING
  PARTIALLY_RECEIVED
  FULLY_RECEIVED

  @@schema("equipment")
}

enum OrderType {
  PURCHASE    // 유환 (일반 발주)
  DUTY_FREE   // 무환통관 (워런티/샘플/대체품 등)

  @@schema("equipment")
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  CANCELLED

  @@schema("equipment")
}

// ─── P-1. ProductMaster (장비 마스터) ──────────

model ProductMaster {
  id              String         @id @default(cuid())
  name            String
  modelName       String         @map("model_name")
  manufacturer    String
  // v1.6 신규 (2026-05-13): SKU 모델 도입
  masterCode      String?        @map("master_code")        // 짧은 코드 3~6자 (SKU code 생성용)
  keyAttributes   Json?          @map("key_attributes")     // ["length", "end_type"] 등 SKU code 핵심 축
  unitOfMeasure   String?        @map("unit_of_measure")    // "EA"|"m"|"kg"|"L"|"식"
  defaultCurrency OrderCurrency? @map("default_currency")
  referencePrice  Decimal?       @map("reference_price") @db.Decimal(12, 2)
  specs           Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orderItems         OverseasOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]   @relation("PMPurchaseItems")
  inventoryItems     InventoryItem[]
  variants           ProductVariant[]
  bomItems           BomItem[]
  bundleShipmentItems BundleShipmentItem[]

  @@unique([manufacturer, modelName], name: "manufacturer_model")
  @@map("product_masters")
  @@schema("equipment")
}

// v1.6 신규 (2026-05-13): SKU = 옵션 조합별 단위
model ProductVariant {
  id              String         @id @default(cuid())
  productMasterId String         @map("product_master_id")
  skuCode         String?        @unique @map("sku_code")     // 의미 코드 ("M6F-10M-FE")
  variantSpecs    Json           @default("{}") @map("variant_specs")  // { length: "10m", ... }
  isActive        Boolean        @default(true) @map("is_active")

  productMaster   ProductMaster  @relation(fields: [productMasterId], references: [id], onDelete: Cascade)
  inventoryItems  InventoryItem[]
  bomItems        BomItem[]
  bundleShipmentItems BundleShipmentItem[]
  overseasOrderItems  OverseasOrderItem[] @relation("PVOverseasItems")
  purchaseOrderItems  PurchaseOrderItem[] @relation("PVPurchaseItems")
  inboundRequestItems InboundRequestItem[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@unique([productMasterId, variantSpecs])
  @@index([productMasterId])
  @@map("product_variants")
  @@schema("equipment")
}

// ─── P-S. Supplier (제조사/공급사) ─────────────

model Supplier {
  id           String   @id @default(cuid())
  name         String   @unique                   // 제조사/공급사명
  country      String?                            // 국가
  contactName  String?  @map("contact_name")      // 대표 담당자 (legacy)
  phone        String?
  email        String?
  website        String?
  address        String?
  businessNumber String?  @map("business_number")  // 사업자등록번호
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  contacts     SupplierContact[]
  inventoryItems InventoryItem[]

  @@map("suppliers")
  @@schema("equipment")
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String   @map("supplier_id")
  name       String
  position   String?                              // 직급
  phone      String?
  email      String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_contacts")
  @@schema("equipment")
}

// ─── P-2. Contract (계약) ─────────────────────

model Contract {
  id              String         @id @default(cuid())
  contractNumber  String         @unique @map("contract_number") // #YY-NN
  name            String                                        // 계약건명(품명)
  client          String                                        // 고객사
  clientContact   String?        @map("client_contact")          // 담당자
  manufacturer    String?                                       // 제작사(공급사)
  category        String         @default("물품")                // 구분: 물품/용역
  contractType    String         @default("내자") @map("contract_type") // 내자/외자
  contractDate    DateTime?      @map("contract_date") @db.Date // 계약일자
  deadline        DateTime?                        @db.Date      // 납기
  manager         String?                                        // 계약담당
  status          ContractStatus @default(ACTIVE)
  notes           String?

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders      OverseasOrder[]
  settlements ImportCostSettlement[]

  @@index([status])
  @@map("contracts")
  @@schema("equipment")
}

// ─── P-3. OverseasOrder (해외 발주) ───────────

model OverseasOrder {
  id                     String        @id @default(cuid())
  contractId             String        @map("contract_id")
  orderNumber            String        @unique @map("order_number")
  manufacturer           String
  currency               OrderCurrency
  orderType              OrderType     @default(PURCHASE) @map("order_type")
  status                 OrderStatus   @default(DRAFT)

  orderDate              DateTime?     @map("order_date") @db.Date
  estimatedProductionEnd DateTime?     @map("estimated_production_end") @db.Date
  estimatedShipDate      DateTime?     @map("estimated_ship_date") @db.Date
  actualShipDate         DateTime?     @map("actual_ship_date") @db.Date
  customsDate            DateTime?     @map("customs_date") @db.Date
  arrivalDate            DateTime?     @map("arrival_date") @db.Date

  productionProgress Int     @default(0) @map("production_progress")
  productionNotes    String? @map("production_notes")

  arrivalLocation String? @map("arrival_location")
  orderedBy       String  @map("ordered_by")
  customsHandler  String? @map("customs_handler")

  invoiceNo  String?   @map("invoice_no")
  dueDate    DateTime? @map("due_date") @db.Date
  oaNumber   String?   @map("oa_number")

  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)
  totalAmountKRW Decimal? @map("total_amount_krw") @db.Decimal(14, 0)

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contract        Contract              @relation(fields: [contractId], references: [id])
  items           OverseasOrderItem[]
  progressLogs    OrderProgressLog[]
  costSettlements ImportCostSettlement[]

  @@index([contractId])
  @@index([status])
  @@index([orderedBy])
  @@index([currency])
  @@map("overseas_orders")
  @@schema("equipment")
}

// ─── P-4. OverseasOrderItem (발주 품목) ───────

model OverseasOrderItem {
  id               String                 @id @default(cuid())
  orderId          String                 @map("order_id")
  productMasterId  String?                @map("product_master_id")
  variantId        String?                @map("variant_id")   // v1.6 신규
  name             String
  spec             String?
  quantity         Int
  receivedQuantity Int                    @default(0) @map("received_quantity")
  unitPrice        Decimal                @map("unit_price") @db.Decimal(12, 2)
  amount           Decimal                @db.Decimal(12, 2)
  receiptStatus    OrderItemReceiptStatus @default(PENDING) @map("receipt_status")
  notes            String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order          OverseasOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productMaster  ProductMaster? @relation(fields: [productMasterId], references: [id])
  variant        ProductVariant? @relation("PVOverseasItems", fields: [variantId], references: [id])
  inventoryItems InventoryItem[] @relation("OrderItemInventory")
  costExtras     CostExtra[]

  @@index([orderId])
  @@index([variantId])
  @@map("overseas_order_items")
  @@schema("equipment")
}

// ─── P-5. OrderProgressLog (진행 이력) ────────

model OrderProgressLog {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  progress  Int
  note      String?
  updatedBy String   @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")

  order OverseasOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_progress_logs")
  @@schema("equipment")
}

// ─── Phase 3: 재고 (InventoryItem) ────────────

model InventoryItem {
  id                    String                @id @default(cuid())
  inventoryNo           String                @unique @map("inventory_no")
  itemName              String?               @map("item_name")
  manufacturer          String?
  productMasterId       String?               @map("product_master_id")
  variantId             String?               @map("variant_id")  // v1.6 신규
  serialNumber          String?               @map("serial_number")
  trackingMode          InventoryTrackingMode @default(INDIVIDUAL) @map("tracking_mode")
  quantity              Int                   @default(1)         // = totalQuantity (위치별 합산)
  category              InventoryCategory     @default(PRODUCT)
  currentLocation       String?               @map("current_location")  // ⚠ deprecated v1.6 — InventoryItemLocation으로 분산. 마이그레이션 종료 후 제거
  currentStatus         InventoryStatus       @default(IN_STOCK) @map("current_status")

  unitPrice             Decimal?              @map("unit_price") @db.Decimal(12, 2)
  supplyAmount          Decimal?              @map("supply_amount") @db.Decimal(14, 0)
  totalAmount           Decimal?              @map("total_amount") @db.Decimal(14, 0)
  totalAdditionalCost   Decimal               @default(0) @map("total_additional_cost") @db.Decimal(14, 0)
  totalCostOfOwnership  Decimal               @default(0) @map("total_cost_of_ownership") @db.Decimal(14, 0)

  projectName           String?               @map("project_name")
  assigneeName          String?               @map("assignee_name")
  sourceType            InventorySourceType?  @map("source_type")
  sourceId              String?               @map("source_id")
  orderItemId           String?               @map("order_item_id")
  costSettlementId      String?               @map("cost_settlement_id")
  supplierId            String?               @map("supplier_id")
  inboundRequestId      String?               @map("inbound_request_id")  // v1.6 신규 (입고 큐 출처)

  notes                 String?
  createdBy             String                @map("created_by")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  productMaster         ProductMaster?        @relation(fields: [productMasterId], references: [id])
  variant               ProductVariant?       @relation(fields: [variantId], references: [id])
  orderItem             OverseasOrderItem?    @relation("OrderItemInventory", fields: [orderItemId], references: [id])
  supplierRef           Supplier?             @relation(fields: [supplierId], references: [id])
  inboundRequest        InboundRequest?       @relation(fields: [inboundRequestId], references: [id])
  locations             InventoryItemLocation[]
  bundleShipmentItems   BundleShipmentItem[]
  transactions          InventoryTransaction[]
  costEvents            AssetCostEvent[]
  auditItems            InventoryAuditItem[]

  @@index([category])
  @@index([currentLocation])
  @@index([currentStatus])
  @@index([sourceType, sourceId])
  @@index([supplierId])
  @@index([variantId])
  @@index([inboundRequestId])
  @@map("inventory_items")
  @@schema("equipment")
}

// v1.6 신규 (2026-05-13): 1 inventory = N location 분산
model InventoryItemLocation {
  id              String          @id @default(cuid())
  inventoryItemId String          @map("inventory_item_id")
  locationId      String          @map("location_id")
  quantity        Int

  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  location        StorageLocation @relation(fields: [locationId], references: [id])
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([inventoryItemId, locationId])
  @@index([locationId])
  @@map("inventory_item_locations")
  @@schema("equipment")
}

// ─── Phase 3: 입출고 이력 (InventoryTransaction) ──

model InventoryTransaction {
  id              String                    @id @default(cuid())
  inventoryItemId String                    @map("inventory_item_id")
  type            InventoryTransactionType
  date            DateTime                  @db.Date
  sequenceNo      String?                   @map("sequence_no")
  quantity        Int                       @default(1)
  fromLocation    String?                   @map("from_location")
  toLocation      String?                   @map("to_location")
  deliveryTo      String?                   @map("delivery_to")
  supplier        String?
  projectName     String?                   @map("project_name")
  assigneeName    String?                   @map("assignee_name")
  costNumber      String?                   @map("cost_number")
  notes           String?

  createdBy       String                    @map("created_by")
  createdAt       DateTime                  @default(now()) @map("created_at")

  inventoryItem   InventoryItem             @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@index([type])
  @@index([date])
  @@map("inventory_transactions")
  @@schema("equipment")
}

// ─── Phase 3: 자산 추가비용 (AssetCostEvent) ──────

model AssetCostEvent {
  id              String        @id @default(cuid())
  inventoryItemId String        @map("inventory_item_id")
  type            AssetCostType
  title           String
  description     String?
  vendor          String?
  cost            Decimal       @db.Decimal(14, 0)
  currency        OrderCurrency?
  foreignAmount   Decimal?      @map("foreign_amount") @db.Decimal(12, 2)
  exchangeRate    Decimal?      @map("exchange_rate") @db.Decimal(10, 4)
  eventDate       DateTime      @map("event_date") @db.Date
  performedBy     String?       @map("performed_by")
  relatedOrderId  String?       @map("related_order_id")
  notes           String?

  createdBy       String        @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@index([type])
  @@map("asset_cost_events")
  @@schema("equipment")
}

// ─── Phase 4: 지출결의서 후속처리 ─────────────

enum ExpenseFollowUpStatus {
  FINANCE_RECEIVED
  INVENTORY_DECIDED
  ARRIVED
  COMPLETED

  @@schema("equipment")
}

model ExpenseFollowUp {
  id                    String                @id @default(cuid())
  approvalDocumentId    String                @unique @map("approval_document_id")
  status                ExpenseFollowUpStatus @default(FINANCE_RECEIVED)

  receivedBy            String?               @map("received_by")
  receivedAt            DateTime?             @map("received_at")

  isInventoryTarget     Boolean?              @map("is_inventory_target")
  inventoryDecisionBy   String?               @map("inventory_decision_by")
  inventoryDecisionAt   DateTime?             @map("inventory_decision_at")
  inventoryDecisionNote String?               @map("inventory_decision_note")

  arrivalDate           DateTime?             @map("arrival_date") @db.Date
  arrivalLocation       String?               @map("arrival_location")
  arrivalNote           String?               @map("arrival_note")
  confirmedBy           String?               @map("confirmed_by")

  inventoryItemId       String?               @map("inventory_item_id")

  // 결제(송금) 처리 — 입고와 독립. 송금 종류는 approvalDocument.referenceType로 판별
  paymentCompletedAt    DateTime?             @map("payment_completed_at")
  paymentAmount         Decimal?              @map("payment_amount") @db.Decimal(15, 2)
  paymentNote           String?               @map("payment_note")
  paymentBy             String?               @map("payment_by")

  notes                 String?
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  @@index([status])
  @@map("expense_follow_ups")
  @@schema("equipment")
}

// ─── Phase 5: 수입원가정산 ────────────────────

enum CostDutyType {
  TARIFF
  OVERSEAS_FREIGHT
  DOMESTIC_FREIGHT
  CUSTOMS_FEE
  WAREHOUSE_FEE
  HANDLING_FEE

  @@schema("equipment")
}

model ImportCostSettlement {
  id                String   @id @default(cuid())
  orderId           String?  @map("order_id")
  contractId        String?  @map("contract_id")
  declarationNo     String   @unique @map("declaration_no")
  supplier          String
  declarationDate   DateTime @map("declaration_date") @db.Date
  currency          String   @default("USD")

  totalImportCost   Decimal  @map("total_import_cost") @db.Decimal(14, 0)
  totalExtraCost    Decimal  @default(0) @map("total_extra_cost") @db.Decimal(14, 0)
  supplyAmount      Decimal  @map("supply_amount") @db.Decimal(14, 0)
  vat               Decimal  @db.Decimal(14, 0)
  saleInfo          String?  @map("sale_info")

  notes             String?
  createdBy         String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  order             OverseasOrder? @relation(fields: [orderId], references: [id])
  contract          Contract?      @relation(fields: [contractId], references: [id])
  remittances       CostRemittance[]
  duties            CostDuty[]
  extras            CostExtra[]
  items             CostItem[]

  @@index([orderId])
  @@index([contractId])
  @@map("import_cost_settlements")
  @@schema("equipment")
}

model CostRemittance {
  id              String   @id @default(cuid())
  settlementId    String   @map("settlement_id")
  remittanceDate  DateTime @map("remittance_date") @db.Date
  foreignAmount   Decimal  @map("foreign_amount") @db.Decimal(12, 2)
  exchangeRate    Decimal  @map("exchange_rate") @db.Decimal(10, 4)
  krwAmount       Decimal  @map("krw_amount") @db.Decimal(14, 0)
  invoiceNo       String?  @map("invoice_no")
  notes           String?

  settlement      ImportCostSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("cost_remittances")
  @@schema("equipment")
}

model CostDuty {
  id            String       @id @default(cuid())
  settlementId  String       @map("settlement_id")
  type          CostDutyType
  amount        Decimal      @db.Decimal(14, 0)
  vat           Decimal      @default(0) @db.Decimal(14, 0)
  awbNo         String?      @map("awb_no")
  notes         String?

  settlement    ImportCostSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("cost_duties")
  @@schema("equipment")
}

model CostExtra {
  id            String   @id @default(cuid())
  settlementId  String   @map("settlement_id")
  targetItemId  String?  @map("target_item_id")
  name          String
  amount        Decimal  @db.Decimal(14, 0)
  notes         String?

  settlement    ImportCostSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  targetItem    OverseasOrderItem?  @relation(fields: [targetItemId], references: [id])

  @@index([settlementId])
  @@map("cost_extras")
  @@schema("equipment")
}

model CostItem {
  id                String  @id @default(cuid())
  settlementId      String  @map("settlement_id")
  inventoryNo       String? @map("inventory_no")
  name              String
  quantity          Int
  foreignUnitPrice  Decimal? @map("foreign_unit_price") @db.Decimal(12, 2)
  foreignAmount     Decimal? @map("foreign_amount") @db.Decimal(12, 2)
  unitPrice         Decimal @map("unit_price") @db.Decimal(14, 4)
  amount            Decimal @db.Decimal(14, 4)
  adjustedUnitPrice Decimal? @map("adjusted_unit_price") @db.Decimal(14, 4)

  settlement        ImportCostSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("cost_items")
  @@schema("equipment")
}

// ─── Phase 7: 재고 실사 ───────────────────────

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  CANCELLED
  COMPLETED

  @@schema("equipment")
}

enum AuditItemStatus {
  PENDING
  MATCHED
  MISMATCHED
  MISSING

  @@schema("equipment")
}

model InventoryAudit {
  id           String      @id @default(cuid())
  name         String
  status       AuditStatus @default(PLANNED)
  plannedDate  DateTime    @map("planned_date") @db.Date
  startedAt    DateTime?   @map("started_at")
  completedAt  DateTime?   @map("completed_at")
  notes        String?

  createdBy    String      @map("created_by")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  items        InventoryAuditItem[]

  @@map("inventory_audits")
  @@schema("equipment")
}

model InventoryAuditItem {
  id              String          @id @default(cuid())
  auditId         String          @map("audit_id")
  inventoryItemId String          @map("inventory_item_id")
  systemQuantity  Int             @map("system_quantity")
  systemLocation  String?         @map("system_location")
  actualQuantity  Int?            @map("actual_quantity")
  actualLocation  String?         @map("actual_location")
  status          AuditItemStatus @default(PENDING)
  checkedBy       String?         @map("checked_by")
  checkedAt       DateTime?       @map("checked_at")
  photoPath       String?         @map("photo_path")
  notes           String?

  audit           InventoryAudit  @relation(fields: [auditId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id])

  @@index([auditId])
  @@map("inventory_audit_items")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// v1.6 신규 (2026-05-13): InboundRequest 입고 대기 큐
// ─────────────────────────────────────────────

enum InboundRequestStatus {
  PENDING
  RECEIVED
  CANCELED

  @@schema("equipment")
}

enum InboundSourceType {
  OVERSEAS_ORDER
  PURCHASE_ORDER
  EXPENSE_FOLLOWUP
  EXPENSE_SETTLEMENT
  MANUAL

  @@schema("equipment")
}

enum CompletenessFlag {
  AUTO_MATCHED      // 발주 경유 — Master/Variant/Supplier/단가 모두 자동
  PARTIAL           // 일부 정보만
  MANUAL_NEEDED     // 거의 빈 상태 (지출결의서 등)

  @@schema("equipment")
}

model InboundRequest {
  id              String   @id @default(cuid())
  code            String   @unique                          // IR-YYMM-NNNN
  status          InboundRequestStatus @default(PENDING)
  sourceType      InboundSourceType @map("source_type")
  sourceId        String?  @map("source_id")
  sourceDocNumber String?  @map("source_doc_number")        // 표시용
  requesterId     String   @map("requester_id")
  requestedAt     DateTime @default(now()) @map("requested_at")
  notes           String?
  receivedAt      DateTime? @map("received_at")
  receivedBy      String?  @map("received_by")

  items           InboundRequestItem[]
  inventoryItems  InventoryItem[]

  @@index([status])
  @@index([sourceType, sourceId])
  @@map("inbound_requests")
  @@schema("equipment")
}

model InboundRequestItem {
  id                String   @id @default(cuid())
  inboundRequestId  String   @map("inbound_request_id")
  productMasterId   String?  @map("product_master_id")
  variantId         String?  @map("variant_id")
  itemNameRaw       String?  @map("item_name_raw")
  description       String?
  quantity          Int
  unitPrice         Decimal? @map("unit_price") @db.Decimal(12, 2)
  supplierId        String?  @map("supplier_id")
  completenessFlag  CompletenessFlag @default(MANUAL_NEEDED) @map("completeness_flag")

  inboundRequest    InboundRequest @relation(fields: [inboundRequestId], references: [id], onDelete: Cascade)
  variant           ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([inboundRequestId])
  @@map("inbound_request_items")
  @@schema("equipment")
}

// ─────────────────────────────────────────────
// v1.6 신규 (2026-05-13): Bundle BOM (1단계 Flat) + BundleShipment
// ─────────────────────────────────────────────

enum BomSlotType {
  MAIN
  OPTIONAL

  @@schema("equipment")
}

model BomDefinition {
  id              String   @id @default(cuid())
  code            String   @unique                          // 예: "KHOA-OCEAN-V1"
  name            String
  referencePrice  Decimal? @map("reference_price") @db.Decimal(14, 0)   // 사용자 직접 입력
  isActive        Boolean  @default(true) @map("is_active")

  items           BomItem[]
  bundleShipments BundleShipment[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("bom_definitions")
  @@schema("equipment")
}

model BomItem {
  id              String   @id @default(cuid())
  bomDefinitionId String   @map("bom_definition_id")
  productMasterId String   @map("product_master_id")
  variantId       String?  @map("variant_id")
  quantity        Int
  slotType        BomSlotType @default(MAIN) @map("slot_type")
  notes           String?

  bomDefinition   BomDefinition  @relation(fields: [bomDefinitionId], references: [id], onDelete: Cascade)
  productMaster   ProductMaster  @relation(fields: [productMasterId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([bomDefinitionId])
  @@map("bom_items")
  @@schema("equipment")
}

model BundleShipment {
  id              String   @id @default(cuid())
  code            String   @unique                          // BD-YYYY-NNNN
  bomDefinitionId String?  @map("bom_definition_id")
  customerId      String   @map("customer_id")
  projectId       String?  @map("project_id")
  shippedAt       DateTime @map("shipped_at")
  shipTo          String?  @map("ship_to")
  warrantyUntil   DateTime? @map("warranty_until")          // 번들 단위 보증
  totalPrice      Decimal? @map("total_price") @db.Decimal(14, 0)  // 사용자 입력
  notes           String?

  bomDefinition   BomDefinition? @relation(fields: [bomDefinitionId], references: [id])
  customer        Customer       @relation(fields: [customerId], references: [id])
  items           BundleShipmentItem[]
  customerAssets  CustomerAsset[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@map("bundle_shipments")
  @@schema("equipment")
}

model BundleShipmentItem {
  id                String   @id @default(cuid())
  bundleShipmentId  String   @map("bundle_shipment_id")
  productMasterId   String   @map("product_master_id")
  variantId         String?  @map("variant_id")
  quantity          Int
  slotType          BomSlotType @map("slot_type")
  inventoryItemId   String?  @map("inventory_item_id")
  customerAssetId   String?  @map("customer_asset_id")

  bundleShipment    BundleShipment   @relation(fields: [bundleShipmentId], references: [id], onDelete: Cascade)
  productMaster     ProductMaster    @relation(fields: [productMasterId], references: [id])
  variant           ProductVariant?  @relation(fields: [variantId], references: [id])
  inventoryItem     InventoryItem?   @relation(fields: [inventoryItemId], references: [id])
  customerAsset     CustomerAsset?   @relation(fields: [customerAssetId], references: [id])

  @@index([bundleShipmentId])
  @@map("bundle_shipment_items")
  @@schema("equipment")
}
