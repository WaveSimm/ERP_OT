generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["attendance"]
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum WorkType {
  OFFICE
  REMOTE
  FIELD

  @@schema("attendance")
}

enum AttendanceStatus {
  NORMAL
  LATE
  ABSENT
  LEAVE
  HOLIDAY

  @@schema("attendance")
}

enum LeaveType {
  ANNUAL
  HALF          // 반차 (4시간) — 오전/오후 구분은 startTime으로
  QUARTER       // 1/4연차 (2시간)
  FAMILY_DAY    // 가정의날 (1시간)
  FAMILY_DAY_2H // 가정의날 2시간
  BEREAVEMENT   // 경조사 (일 단위)
  SICK
  SPECIAL
  SUBSTITUTE    // 연차대체 (휴일근무 보상 사용)

  @@schema("attendance")
}

enum ApprovalStatus {
  PENDING
  PENDING_2ND
  PENDING_3RD
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED

  @@schema("attendance")
}

enum CheckState {
  NOT_STARTED
  CHECKED_IN
  ON_BREAK
  CHECKED_OUT

  @@schema("attendance")
}

enum EntryType {
  WORK
  FIELD
  TRAINING
  BUSINESS_TRIP
  HALF          // 반차 (4h)
  QUARTER       // 1/4연차 (2h)
  FAMILY_DAY    // 가정의날 (1h)
  FAMILY_DAY_2H // 가정의날 2h
  BEREAVEMENT   // 경조사 (일 단위)
  ANNUAL
  SICK
  SPECIAL
  OT
  SUBSTITUTE    // 연차대체 (휴일근무 보상)

  @@schema("attendance")
}

enum EntrySource {
  MANUAL
  LEAVE_APPROVED
  OT_APPROVED

  @@schema("attendance")
}

// ─────────────────────────────────────────────
// 1. 출퇴근 기록
// ─────────────────────────────────────────────

model AttendanceRecord {
  id             String           @id @default(cuid())
  userId         String
  date           DateTime         @db.Date
  checkIn        DateTime?
  checkOut       DateTime?
  workType       WorkType         @default(OFFICE)
  status         AttendanceStatus @default(NORMAL)
  checkState     CheckState       @default(NOT_STARTED)
  isLate         Boolean          @default(false)
  lateMinutes    Int              @default(0)
  breakMinutes   Int              @default(0)
  netWorkMinutes Int              @default(0)
  note           String?
  checkInSource  String           @default("CAPS")  // 'CAPS' | 'MANUAL' — 사람이 수정하면 MANUAL로 잠금
  checkOutSource String           @default("CAPS")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  breakRecords BreakRecord[]

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("attendance_records")
  @@schema("attendance")
}

model BreakRecord {
  id              String           @id @default(cuid())
  attendanceId    String
  breakOut        DateTime
  breakIn         DateTime?
  durationMinutes Int              @default(0)

  attendance AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@map("break_records")
  @@schema("attendance")
}

// ─────────────────────────────────────────────
// 2. 휴가 관리
// ─────────────────────────────────────────────

model LeaveRequest {
  id           String         @id @default(cuid())
  userId       String
  type         LeaveType
  startDate    DateTime       @db.Date
  endDate      DateTime       @db.Date
  startTime    String?        // 시간단위 휴가 시작시각 HH:mm (반차/1/4/가정의날). 30분 단위
  days         Float
  reason       String
  status            ApprovalStatus @default(PENDING)
  approverId        String?
  secondApproverId  String?
  thirdApproverId   String?
  approvedAt        DateTime?
  rejectReason      String?
  cancelledAt       DateTime?
  // ecount(외부 전자결재) 결재 확인 — 관리부서가 대조 후 체크 (관리>근태현황)
  ecountCheckedAt   DateTime?      @map("ecount_checked_at")
  ecountCheckedById String?        @map("ecount_checked_by_id")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId, status])
  @@index([approverId, status])
  @@index([secondApproverId, status])
  @@index([thirdApproverId, status])
  @@map("leave_requests")
  @@schema("attendance")
}

model LeaveBalance {
  id              String   @id @default(cuid())
  userId          String
  year            Int
  totalDays       Float                  // 기본 연차 (15일 + 근속 가산, 수동)
  longServiceDays Float    @default(0)   // 장기근속 휴가 (10/15/20년 마일스톤, 2년 유효 — 수동 이월)
  usedDays        Float    @default(0)
  pendingDays     Float    @default(0)
  adjustedDays    Float    @default(0)   // 임시 보너스/감산
  // 연차대체 (휴일근무 보상): 휴일근무 1건=+1일. 유효 = 발생연도 다음해 3월말까지.
  substituteDays     Float @default(0)   // 발생 누적 (해당 연도)
  substituteUsedDays Float @default(0)   // 사용
  updatedAt       DateTime @updatedAt

  @@unique([userId, year])
  @@map("leave_balances")
  @@schema("attendance")
}

// ─────────────────────────────────────────────
// 3. 휴일근무 신청 (구 OT 관리, 근태현황 design v1.3 기준 단순화)
//    - 평일 야근 신청 폐기 (출퇴근 시스템으로 자동 인식)
//    - 전일 8h 단일 옵션 (시간 디테일 없음, 임금 연계는 별도)
//    - 결재라인 시스템 활용 (1단계 default, 2~3단계 확장 가능)
//    - 신청 가능 날짜: 회사달력 PUBLIC_HOLIDAY/COMPANY_HOLIDAY + 토/일
// ─────────────────────────────────────────────

model HolidayWorkRequest {
  id               String         @id @default(cuid())
  userId           String
  date             DateTime       @db.Date  // 휴일/주말이어야 (서비스에서 검증)
  reason           String
  status           ApprovalStatus @default(PENDING)
  approverId       String?
  secondApproverId String?
  thirdApproverId  String?
  approvedAt       DateTime?
  rejectReason     String?
  projectId        String?        // 옵션 — 어느 프로젝트 위해
  taskId           String?        // 옵션 — 어느 task 위해 (segment 자동 추론)
  // ecount(외부 전자결재) 결재 확인 — 관리부서가 대조 후 체크 (관리>근태현황)
  ecountCheckedAt   DateTime?     @map("ecount_checked_at")
  ecountCheckedById String?       @map("ecount_checked_by_id")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([userId, status])
  @@index([approverId, status])
  @@index([secondApproverId, status])
  @@index([thirdApproverId, status])
  @@index([date])
  @@map("holiday_work_requests")
  @@schema("attendance")
}

// ─────────────────────────────────────────────
// 4. 근태 기준
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// 7. 개인 근무 스케줄 (유연근무)
// ─────────────────────────────────────────────

model UserWorkSchedule {
  id             String   @id @default(cuid())
  userId         String   @unique
  workStartTime  String   @default("09:30")   // "HH:MM" 형식, 30분 단위
  workEndTime    String   @default("18:30")
  dailyWorkHours Float    @default(8.0)
  updatedBy      String?
  updatedAt      DateTime @updatedAt

  @@map("user_work_schedules")
  @@schema("attendance")
}

model AttendancePolicy {
  id                   String   @id @default(cuid())
  workStartTime        String   @default("09:30")
  workEndTime          String   @default("18:30")
  dailyWorkHours       Float    @default(8.0)
  lateToleranceMinutes Int      @default(0)
  leavePolicy          String   @default("HIRE_DATE")
  annualLeaveBase      Int      @default(15)
  overtimeRates        Json     @default("{\"normal\":1.5,\"holiday\":2.0,\"night\":2.0}")
  updatedBy            String?
  updatedAt            DateTime @updatedAt

  @@map("attendance_policies")
  @@schema("attendance")
}

// 캡스(ADT) e_id ↔ ERP 사용자 매핑 (caps-sync 워커가 사용)
model CapsUserMap {
  eId       Int      @id
  userId    String
  capsName  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([userId])
  @@map("caps_user_map")
  @@schema("attendance")
}

// 캡스 증분 동기화 워터마크
model CapsSyncState {
  id         Int      @id
  lastUptime String   @default("00000000000000") @db.VarChar(14)
  updatedAt  DateTime @default(now())

  @@map("caps_sync_state")
  @@schema("attendance")
}

// ─────────────────────────────────────────────
// 5. 공휴일
// ─────────────────────────────────────────────

model PublicHoliday {
  id   String   @id @default(cuid())
  date DateTime @db.Date
  name String
  year Int

  @@unique([date])
  @@index([year])
  @@map("public_holidays")
  @@schema("attendance")
}

// ─────────────────────────────────────────────
// 6. 알림
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// 8. 근태현황 캘린더 (Work Schedule Entries)
// ─────────────────────────────────────────────

model WorkScheduleEntry {
  id          String      @id @default(cuid())
  userId      String
  date        DateTime    @db.Date
  entryType   EntryType
  startTime   String?     // "HH:mm" 형식
  endTime     String?     // "HH:mm" 형식
  label       String?
  groupId     String?     // 여러 날 근태를 묶는 그룹 ID
  sourceType  EntrySource @default(MANUAL)
  sourceId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, date, entryType, sourceId])
  @@index([userId, date])
  @@index([date])
  @@index([sourceId])
  @@map("work_schedule_entries")
  @@schema("attendance")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  source    String   @default("attendance")
  title     String
  body      String
  isRead    Boolean  @default(false)
  priority  Int      @default(2)
  linkUrl   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
  @@schema("attendance")
}
