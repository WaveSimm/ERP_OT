# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_password
POSTGRES_DB=erp_ot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_password

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=erp_user
RABBITMQ_PASS=erp_password

# ─── JWT Secrets (CHANGE IN PRODUCTION) ───────────────────────────────────────
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# ─── Admin Account (Initial Setup) ────────────────────────────────────────────
ADMIN_EMAIL=admin@erp-ot.local
ADMIN_INITIAL_PASSWORD=Admin1234!

# ─── Internal Service Communication ───────────────────────────────────────────
INTERNAL_API_TOKEN=your_internal_token_here

# ─── Service URLs (for inter-service communication) ──────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
PROJECT_SERVICE_URL=http://localhost:3003
ATTENDANCE_SERVICE_URL=http://localhost:3004

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PROJECT_SERVICE_URL=http://localhost:3003
NEXT_PUBLIC_ATTENDANCE_SERVICE_URL=http://localhost:3004

# ─── External APIs ────────────────────────────────────────────────────────────
# KASI 한국천문연구원 특일 정보 API (회사달력 한국 공휴일 자동 갱신)
# 발급: data.go.kr → 로그인 → 마이페이지 → 인증키 발급내역 → 일반 인증키(Decoding)
# 미설정 시 한국 공휴일 자동 갱신만 비활성, 다른 기능은 정상 동작
KASI_API_KEY=

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
