[Unit]
Description=ERP_OT 백업 (DB 덤프 + uploads tar) — 1회 실행
Documentation=https://github.com/WaveSimm/ERP_OT (docs/04-operation)
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
# erp-ot-backup(도구 컨테이너, idle 상주)에서 백업 스크립트 1회 실행.
#   컨테이너 env(POSTGRES_*)·볼륨(/backups,/uploads_*)을 그대로 사용.
ExecStart=/usr/bin/docker exec erp-ot-backup sh /scripts/backup-run.sh
# 컨테이너가 없으면(재생성 중) 실패 — timer Persistent 가 다음에 보정.
TimeoutStartSec=1800
